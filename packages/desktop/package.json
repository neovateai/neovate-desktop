{
  "name": "neovate-desktop",
  "version": "0.0.0",
  "description": "An Electron application with React and TypeScript",
  "homepage": "https://neovateai.dev",
  "bugs": {
    "url": "https://github.com/neovateai/neovate-desktop/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/neovateai/neovate-desktop/"
  },
  "main": "./dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsgo --noEmit -p tsconfig.node.json && tsgo --noEmit -p tsconfig.web.json",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "bun run build && electron-builder --dir --config configs/electron-builder.mjs",
    "build:mac": "bun run build && electron-builder --mac --config configs/electron-builder.mjs",
    "build:mac:dev": "bun run build && BUILD_ENV=dev electron-builder --mac --config configs/electron-builder.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "bun run build && playwright test",
    "test:e2e:no-build": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@anthropic-ai/sdk": "~0.78.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@orpc/contract": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.0.3",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tiptap/extension-mention": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "adm-zip": "^0.5.16",
    "ai": "^6.0.116",
    "ansi-to-react": "^6.2.6",
    "chokidar": "^5.0.0",
    "date-fns": "^4.1.0",
    "debug": "^4.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "immer": "^11.1.4",
    "minimatch": "^10.2.4",
    "motion": "^12.35.0",
    "node-pty": "^1.1.0",
    "react-i18next": "^16.5.4",
    "shiki": "^4.0.1",
    "simple-git": "^3.32.3",
    "streamdown": "^2.3.0",
    "tar": "^7.5.10",
    "tokenlens": "^1.3.1",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@base-ui/react": "^1.2.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/react": "^1.1.5",
    "@orpc/client": "^1.13.5",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/debug": "^4.1.12",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "~40.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.1",
    "react-grab": "^0.1.26",
    "react-scan": "^0.5.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.2.6",
    "vitest": "^4.0.18",
    "zustand": "^5.0.11"
  }
}
